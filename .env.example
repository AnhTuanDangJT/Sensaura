# Copy to `.env.local` and fill in values. Restart `npm run dev` after changes.

# --- MongoDB (Atlas) — stores users and artwork metadata (title, status, URLs, etc.) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
# Optional database name (default: sensaura)
MONGODB_DB_NAME=sensaura

# --- Supabase — file storage for uploads (images, PDFs, audio) ---
# Project Settings → API: Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Project Settings → API: service_role (server-only; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage → create a public bucket (e.g. name: artworks) for public URLs
SUPABASE_ARTWORKS_BUCKET=artworks

# --- Session cookie signing (generate a long random string, e.g. openssl rand -hex 32) ---
SESSION_SECRET=replace-with-at-least-32-random-characters

# --- Admin: only this email gets ADMIN; everyone else is USER (optional override) ---
ADMIN_EMAIL=dganhtuan.2k5@gmail.com
# Same email as ADMIN_EMAIL — required for Admin nav in the UI (safe to expose publicly)
NEXT_PUBLIC_ADMIN_EMAIL=dganhtuan.2k5@gmail.com

# Optional: when you connect the Spring Boot API (ai-backend)
# NEXT_PUBLIC_API_URL=https://your-api.example.com
